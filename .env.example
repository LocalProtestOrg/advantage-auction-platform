# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=24h

# ── Database ──────────────────────────────────────────────────────────────────
# Cloud (Neon / Railway Postgres / Supabase) — takes priority over individual vars
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Local dev fallback (used when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=advantage_auction
DB_USER=postgres
DB_PASSWORD=yourpassword

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@advantageauction.bid

# ── E2E test fixtures (dev only) ──────────────────────────────────────────────
TEST_AUCTION_ID=565f9db4-1154-496d-bce8-f8cfb828d5f3
