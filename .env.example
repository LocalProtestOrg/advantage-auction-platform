# Advantage Auction Platform — Environment Variables
#
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env — it is gitignored.
# NEVER put real credentials in this file — use only placeholders.
#
# Production secrets are set in Railway environment variables panel.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production
FRONTEND_URL=https://your-app.vercel.app
# Canonical public base used to build absolute links (emails, share-meta
# canonical/og:url/og:image). Single origin, never a comma-list. Already set in
# the live env. Falls back to the first FRONTEND_URL origin when unset.
PUBLIC_BASE_URL=https://bid.advantage.bid

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars
JWT_EXPIRES_IN=24h

# ── Database ──────────────────────────────────────────────────────────────────
# Cloud connection string (Neon / Railway / Supabase) — takes priority
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Local dev fallback (used only when DATABASE_URL is not set)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=advantage_auction
DB_USER=postgres
DB_PASSWORD=your-local-db-password

# ── Stripe ────────────────────────────────────────────────────────────────────
# Use sk_test_... for sandbox, sk_live_... only in production with explicit approval
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# From Stripe dashboard → Webhooks → [endpoint] → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cloudinary ────────────────────────────────────────────────────────────────
# From Cloudinary dashboard → Settings → Access Keys
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@advantageauction.bid

# ── Anthropic (AI features) ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── E2E Test Fixtures (dev only) ──────────────────────────────────────────────
TEST_AUCTION_ID=565f9db4-1154-496d-bce8-f8cfb828d5f3

# ── Auction geocoding (homepage discovery map) ────────────────────────────────
# Mapbox Permanent Geocoding token. The permanent tier is required because the
# platform STORES coordinates on the auction record; the default temporary tier
# forbids persisting results.
# Unset = geocoding reports "unconfigured" and is skipped. Auctions still save and
# publish normally; an admin can set coordinates by hand or retry later.
MAPBOX_GEOCODING_TOKEN=pk.your-mapbox-token-here
